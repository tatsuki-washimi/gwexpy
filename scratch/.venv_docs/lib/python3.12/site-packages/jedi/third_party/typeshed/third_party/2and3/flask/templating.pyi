from collections.abc import Iterable
from typing import Any, Union

from jinja2 import BaseLoader
from jinja2 import Environment as BaseEnvironment

class Environment(BaseEnvironment):
    app: Any = ...
    def __init__(self, app: Any, **options: Any) -> None: ...

class DispatchingJinjaLoader(BaseLoader):
    app: Any = ...
    def __init__(self, app: Any) -> None: ...
    def get_source(self, environment: Any, template: Any): ...
    def list_templates(self): ...

def render_template(template_name_or_list: Union[str, Iterable[str]], **context: Any) -> str: ...
def render_template_string(source: str, **context: Any) -> str: ...
