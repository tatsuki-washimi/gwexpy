from collections.abc import Callable, Iterator
from logging import Logger
from typing import IO, Any, Optional, Union

from paramiko.channel import Channel
from paramiko.sftp import BaseSFTP
from paramiko.sftp_attr import SFTPAttributes
from paramiko.sftp_file import SFTPFile
from paramiko.transport import Transport
from paramiko.util import ClosingContextManager

_Callback = Callable[[int, int], Any]

b_slash: bytes

class SFTPClient(BaseSFTP, ClosingContextManager):
    sock: Channel
    ultra_debug: bool
    request_number: int
    logger: Logger
    def __init__(self, sock: Channel) -> None: ...
    @classmethod
    def from_transport(
        cls, t: Transport, window_size: Optional[int] = ..., max_packet_size: Optional[int] = ...
    ) -> Optional[SFTPClient]: ...
    def close(self) -> None: ...
    def get_channel(self) -> Optional[Channel]: ...
    def listdir(self, path: str = ...) -> list[str]: ...
    def listdir_attr(self, path: str = ...) -> list[SFTPAttributes]: ...
    def listdir_iter(self, path: Union[bytes, str] = ..., read_aheads: int = ...) -> Iterator[SFTPAttributes]: ...
    def open(self, filename: Union[bytes, str], mode: str = ..., bufsize: int = ...) -> SFTPFile: ...
    file = open
    def remove(self, path: Union[bytes, str]) -> None: ...
    unlink = remove
    def rename(self, oldpath: Union[bytes, str], newpath: Union[bytes, str]) -> None: ...
    def posix_rename(self, oldpath: Union[bytes, str], newpath: Union[bytes, str]) -> None: ...
    def mkdir(self, path: Union[bytes, str], mode: int = ...) -> None: ...
    def rmdir(self, path: Union[bytes, str]) -> None: ...
    def stat(self, path: Union[bytes, str]) -> SFTPAttributes: ...
    def lstat(self, path: Union[bytes, str]) -> SFTPAttributes: ...
    def symlink(self, source: Union[bytes, str], dest: Union[bytes, str]) -> None: ...
    def chmod(self, path: Union[bytes, str], mode: int) -> None: ...
    def chown(self, path: Union[bytes, str], uid: int, gid: int) -> None: ...
    def utime(self, path: Union[bytes, str], times: Optional[tuple[float, float]]) -> None: ...
    def truncate(self, path: Union[bytes, str], size: int) -> None: ...
    def readlink(self, path: Union[bytes, str]) -> Optional[str]: ...
    def normalize(self, path: Union[bytes, str]) -> str: ...
    def chdir(self, path: Union[None, bytes, str] = ...) -> None: ...
    def getcwd(self) -> Optional[str]: ...
    def putfo(
        self,
        fl: IO[bytes],
        remotepath: Union[bytes, str],
        file_size: int = ...,
        callback: Optional[_Callback] = ...,
        confirm: bool = ...,
    ) -> SFTPAttributes: ...
    def put(
        self,
        localpath: Union[bytes, str],
        remotepath: Union[bytes, str],
        callback: Optional[_Callback] = ...,
        confirm: bool = ...,
    ) -> SFTPAttributes: ...
    def getfo(self, remotepath: Union[bytes, str], fl: IO[bytes], callback: Optional[_Callback] = ...) -> int: ...
    def get(self, remotepath: Union[bytes, str], localpath: Union[bytes, str], callback: Optional[_Callback] = ...) -> None: ...

class SFTP(SFTPClient): ...
