from collections.abc import Callable, Generator, Mapping, MutableMapping
from datetime import datetime
from typing import (
    IO,
    Any,
    Optional,
    Union,
)

_serializer = Any  # must be an object that has "dumps" and "loads" attributes (e.g. the json module)

def want_bytes(s: Union[str, bytes], encoding: str = ..., errors: str = ...) -> bytes: ...

class BadData(Exception):
    message: str
    def __init__(self, message: str) -> None: ...

class BadPayload(BadData):
    original_error: Optional[Exception]
    def __init__(self, message: str, original_error: Optional[Exception] = ...) -> None: ...

class BadSignature(BadData):
    payload: Optional[Any]
    def __init__(self, message: str, payload: Optional[Any] = ...) -> None: ...

class BadTimeSignature(BadSignature):
    date_signed: Optional[int]
    def __init__(self, message: str, payload: Optional[Any] = ..., date_signed: Optional[int] = ...) -> None: ...

class BadHeader(BadSignature):
    header: Any
    original_error: Any
    def __init__(
        self, message: str, payload: Optional[Any] = ..., header: Optional[Any] = ..., original_error: Optional[Any] = ...
    ) -> None: ...

class SignatureExpired(BadTimeSignature): ...

def base64_encode(string: Union[str, bytes]) -> bytes: ...
def base64_decode(string: Union[str, bytes]) -> bytes: ...

class SigningAlgorithm:
    def get_signature(self, key: bytes, value: bytes) -> bytes: ...
    def verify_signature(self, key: bytes, value: bytes, sig: bytes) -> bool: ...

class NoneAlgorithm(SigningAlgorithm):
    def get_signature(self, key: bytes, value: bytes) -> bytes: ...

class HMACAlgorithm(SigningAlgorithm):
    default_digest_method: Callable[..., Any]
    digest_method: Callable[..., Any]
    def __init__(self, digest_method: Optional[Callable[..., Any]] = ...) -> None: ...
    def get_signature(self, key: bytes, value: bytes) -> bytes: ...

class Signer:
    default_digest_method: Callable[..., Any] = ...
    default_key_derivation: str = ...

    secret_key: bytes
    sep: bytes
    salt: Union[str, bytes]
    key_derivation: str
    digest_method: Callable[..., Any]
    algorithm: SigningAlgorithm
    def __init__(
        self,
        secret_key: Union[str, bytes],
        salt: Optional[Union[str, bytes]] = ...,
        sep: Optional[Union[str, bytes]] = ...,
        key_derivation: Optional[str] = ...,
        digest_method: Optional[Callable[..., Any]] = ...,
        algorithm: Optional[SigningAlgorithm] = ...,
    ) -> None: ...
    def derive_key(self) -> bytes: ...
    def get_signature(self, value: Union[str, bytes]) -> bytes: ...
    def sign(self, value: Union[str, bytes]) -> bytes: ...
    def verify_signature(self, value: bytes, sig: Union[str, bytes]) -> bool: ...
    def unsign(self, signed_value: Union[str, bytes]) -> bytes: ...
    def validate(self, signed_value: Union[str, bytes]) -> bool: ...

class TimestampSigner(Signer):
    def get_timestamp(self) -> int: ...
    def timestamp_to_datetime(self, ts: float) -> datetime: ...
    def sign(self, value: Union[str, bytes]) -> bytes: ...
    def unsign(
        self, value: Union[str, bytes], max_age: Optional[int] = ..., return_timestamp: bool = ...
    ) -> Any: ...  # morally -> Union[bytes, Tuple[bytes, datetime]]
    def validate(self, signed_value: Union[str, bytes], max_age: Optional[int] = ...) -> bool: ...

class Serializer:
    default_serializer: _serializer = ...
    default_signer: Callable[..., Signer] = ...

    secret_key: bytes
    salt: bytes
    serializer: _serializer
    is_text_serializer: bool
    signer: Callable[..., Signer]
    signer_kwargs: MutableMapping[str, Any]
    def __init__(
        self,
        secret_key: Union[str, bytes],
        salt: Optional[Union[str, bytes]] = ...,
        serializer: Optional[_serializer] = ...,
        signer: Optional[Callable[..., Signer]] = ...,
        signer_kwargs: Optional[MutableMapping[str, Any]] = ...,
    ) -> None: ...
    def load_payload(self, payload: bytes, serializer: Optional[_serializer] = ...) -> Any: ...
    def dump_payload(self, obj: Any) -> bytes: ...
    def make_signer(self, salt: Optional[Union[str, bytes]] = ...) -> Signer: ...
    def iter_unsigners(self, salt: Optional[Union[str, bytes]] = ...) -> Generator[Any]: ...
    def dumps(self, obj: Any, salt: Optional[Union[str, bytes]] = ...) -> Any: ...  # morally -> Union[str, bytes]
    def dump(self, obj: Any, f: IO[Any], salt: Optional[Union[str, bytes]] = ...) -> None: ...
    def loads(self, s: Union[str, bytes], salt: Optional[Union[str, bytes]] = ...) -> Any: ...
    def load(self, f: IO[Any], salt: Optional[Union[str, bytes]] = ...) -> Any: ...
    def loads_unsafe(self, s: Union[str, bytes], salt: Optional[Union[str, bytes]] = ...) -> tuple[bool, Optional[Any]]: ...
    def load_unsafe(self, f: IO[Any], salt: Optional[Union[str, bytes]] = ...) -> tuple[bool, Optional[Any]]: ...

class TimedSerializer(Serializer):
    def loads(
        self,
        s: Union[str, bytes],
        salt: Optional[Union[str, bytes]] = ...,
        max_age: Optional[int] = ...,
        return_timestamp: bool = ...,
    ) -> Any: ...  # morally -> Union[Any, Tuple[Any, datetime]]
    def loads_unsafe(
        self, s: Union[str, bytes], salt: Optional[Union[str, bytes]] = ..., max_age: Optional[int] = ...
    ) -> tuple[bool, Any]: ...

class JSONWebSignatureSerializer(Serializer):
    jws_algorithms: MutableMapping[str, SigningAlgorithm] = ...
    default_algorithm: str = ...
    default_serializer: Any = ...

    algorithm_name: str
    algorithm: SigningAlgorithm
    def __init__(
        self,
        secret_key: Union[str, bytes],
        salt: Optional[Union[str, bytes]] = ...,
        serializer: Optional[_serializer] = ...,
        signer: Optional[Callable[..., Signer]] = ...,
        signer_kwargs: Optional[MutableMapping[str, Any]] = ...,
        algorithm_name: Optional[str] = ...,
    ) -> None: ...
    def load_payload(
        self, payload: Union[str, bytes], serializer: Optional[_serializer] = ..., return_header: bool = ...
    ) -> Any: ...  # morally -> Union[Any, Tuple[Any, MutableMapping[str, Any]]]
    def dump_payload(self, header: Mapping[str, Any], obj: Any) -> bytes: ...  # type: ignore
    def make_algorithm(self, algorithm_name: str) -> SigningAlgorithm: ...
    def make_signer(self, salt: Optional[Union[str, bytes]] = ..., algorithm: SigningAlgorithm = ...) -> Signer: ...
    def make_header(self, header_fields: Optional[Mapping[str, Any]]) -> MutableMapping[str, Any]: ...
    def dumps(
        self, obj: Any, salt: Optional[Union[str, bytes]] = ..., header_fields: Optional[Mapping[str, Any]] = ...
    ) -> bytes: ...
    def loads(
        self, s: Union[str, bytes], salt: Optional[Union[str, bytes]] = ..., return_header: bool = ...
    ) -> Any: ...  # morally -> Union[Any, Tuple[Any, MutableMapping[str, Any]]]
    def loads_unsafe(
        self, s: Union[str, bytes], salt: Optional[Union[str, bytes]] = ..., return_header: bool = ...
    ) -> tuple[bool, Any]: ...

class TimedJSONWebSignatureSerializer(JSONWebSignatureSerializer):
    DEFAULT_EXPIRES_IN: int = ...
    expires_in: int
    def __init__(
        self,
        secret_key: Union[str, bytes],
        expires_in: Optional[int] = ...,
        salt: Optional[Union[str, bytes]] = ...,
        serializer: Optional[_serializer] = ...,
        signer: Optional[Callable[..., Signer]] = ...,
        signer_kwargs: Optional[MutableMapping[str, Any]] = ...,
        algorithm_name: Optional[str] = ...,
    ) -> None: ...
    def make_header(self, header_fields: Optional[Mapping[str, Any]]) -> MutableMapping[str, Any]: ...
    def loads(
        self, s: Union[str, bytes], salt: Optional[Union[str, bytes]] = ..., return_header: bool = ...
    ) -> Any: ...  # morally -> Union[Any, Tuple[Any, MutableMapping[str, Any]]]
    def get_issue_date(self, header: Mapping[str, Any]) -> Optional[datetime]: ...
    def now(self) -> int: ...

class _URLSafeSerializerMixin:
    default_serializer: _serializer = ...
    def load_payload(self, payload: bytes, serializer: Optional[_serializer] = ...) -> Any: ...
    def dump_payload(self, obj: Any) -> bytes: ...

class URLSafeSerializer(_URLSafeSerializerMixin, Serializer): ...
class URLSafeTimedSerializer(_URLSafeSerializerMixin, TimedSerializer): ...
