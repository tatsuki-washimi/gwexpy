from collections.abc import Iterable, Mapping, MutableMapping
from typing import Any

from _typeshed.wsgi import StartResponse, WSGIApplication, WSGIEnvironment

_Opts = Mapping[str, Any]
_MutableOpts = MutableMapping[str, Any]

class ProxyMiddleware:
    app: WSGIApplication
    targets: dict[str, _MutableOpts]
    def __init__(
        self, app: WSGIApplication, targets: Mapping[str, _MutableOpts], chunk_size: int = ..., timeout: int = ...
    ) -> None: ...
    def proxy_to(self, opts: _Opts, path: str, prefix: str) -> WSGIApplication: ...
    def __call__(self, environ: WSGIEnvironment, start_response: StartResponse) -> Iterable[bytes]: ...
