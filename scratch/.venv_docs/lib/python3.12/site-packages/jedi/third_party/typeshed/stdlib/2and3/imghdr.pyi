import os
import sys
from collections.abc import Callable
from typing import (
    Any,
    BinaryIO,
    Optional,
    Protocol,
    Union,
    overload,
)

class _ReadableBinary(Protocol):
    def tell(self) -> int: ...
    def read(self, size: int) -> bytes: ...
    def seek(self, offset: int) -> Any: ...

if sys.version_info >= (3, 6):
    _File = Union[str, os.PathLike[str], _ReadableBinary]
else:
    _File = Union[str, _ReadableBinary]

@overload
def what(file: _File, h: None = ...) -> Optional[str]: ...
@overload
def what(file: Any, h: bytes) -> Optional[str]: ...

tests: list[Callable[[bytes, Optional[BinaryIO]], Optional[str]]]
