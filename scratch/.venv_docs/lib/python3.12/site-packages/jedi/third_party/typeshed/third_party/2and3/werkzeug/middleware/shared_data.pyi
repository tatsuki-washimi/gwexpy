import datetime
from collections.abc import Callable, Iterable, Mapping
from typing import IO, Optional, Union

from _typeshed.wsgi import StartResponse, WSGIApplication, WSGIEnvironment

_V = Union[tuple[str, str], str]

_Opener = Callable[[], tuple[IO[bytes], datetime.datetime, int]]
_Loader = Callable[[Optional[str]], Union[tuple[None, None], tuple[str, _Opener]]]

class SharedDataMiddleware:
    app: WSGIApplication
    exports: list[tuple[str, _Loader]]
    cache: bool
    cache_timeout: float
    def __init__(
        self,
        app: WSGIApplication,
        exports: Union[Mapping[str, _V], Iterable[tuple[str, _V]]],
        disallow: Optional[str] = ...,
        cache: bool = ...,
        cache_timeout: float = ...,
        fallback_mimetype: str = ...,
    ) -> None: ...
    def is_allowed(self, filename: str) -> bool: ...
    def get_file_loader(self, filename: str) -> _Loader: ...
    def get_package_loader(self, package: str, package_path: str) -> _Loader: ...
    def get_directory_loader(self, directory: str) -> _Loader: ...
    def generate_etag(self, mtime: datetime.datetime, file_size: int, real_filename: Union[str, bytes]) -> str: ...
    def __call__(self, environment: WSGIEnvironment, start_response: StartResponse) -> WSGIApplication: ...
