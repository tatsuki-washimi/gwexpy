from collections.abc import Iterable
from typing import Any, Optional

def colored(
    text: str, color: Optional[str] = ..., on_color: Optional[str] = ..., attrs: Optional[Iterable[str]] = ...
) -> str: ...
def cprint(
    text: str, color: Optional[str] = ..., on_color: Optional[str] = ..., attrs: Optional[Iterable[str]] = ..., **kwargs: Any
) -> None: ...
