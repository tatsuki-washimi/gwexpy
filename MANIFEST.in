include CHANGELOG.md
include LICENSE.txt
include README.md
include pyproject.toml
prune docs/_static/samples
prune gwexpy/gui
prune gwexpy/utils/sphinx
prune gwexpy/*/tests
prune tests
recursive-exclude gwexpy *.md
prune .agent
prune .harness
prune docs_internal
prune scratch
prune temp_logs
prune tmp
global-exclude __pycache__ *.py[cod]
