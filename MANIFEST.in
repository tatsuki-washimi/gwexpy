include CHANGELOG.md
include LICENSE.txt
include README.md
recursive-include docs/_static/samples *.csv *.h5 *.txt
include pyproject.toml
prune gwexpy/*/tests
recursive-exclude gwexpy *.md
prune .agent
prune .harness
prune docs_internal
prune scratch
prune temp_logs
prune tmp
global-exclude __pycache__ *.py[cod]
